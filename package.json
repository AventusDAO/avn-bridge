{
  "name": "avn-bridge",
  "version": "1.0.0",
  "description": "AVN T1 standalone contract for AVN parachain and consoritium networks",
  "author": "Aventus Network Services Ltd",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aventus-Network-Services/avn-bridge"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-ledger": "^1.2.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "axios": "^1.11.0",
    "hardhat": "^2.26.1",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-erc1820": "^0.1.0",
    "keccak256": "^1.0.6",
    "merkletreejs": "^0.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^2.1.0",
    "solidity-coverage": "^0.8.16"
  },
  "scripts": {
    "format": "npm run pretty:fix && npm run pretty:sol",
    "pretty:fix": "prettier --config ./.prettierrc.json --write \"**/*.{js,json}\"",
    "pretty:sol": "npx prettier --write --plugin=prettier-plugin-solidity contracts/**/*.sol"
  },
  "overrides": {
    "chalk": "5.3.0",
    "strip-ansi": "7.1.0",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "is-core-module": "2.13.1",
    "error-ex": "1.3.2",
    "has-ansi": "5.0.1"
  }
}
