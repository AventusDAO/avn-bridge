{
  "name": "avn-bridge",
  "version": "1.0.0",
  "description": "Aventus Network Ethereum Bridge",
  "author": "Aventus Network Services Ltd",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aventus-Network-Services/avn-bridge"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-ledger": "^1.2.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@polkadot/api": "^16.5.2",
    "axios": "^1.11.0",
    "dotenv": "^17.2.3",
    "hardhat": "^2.26.3",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-erc1820": "^0.1.0",
    "keccak256": "^1.0.6",
    "merkletreejs": "^0.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^2.1.0",
    "solidity-coverage": "^0.8.16"
  },
  "scripts": {
    "format": "npm run pretty:fix && npm run pretty:sol",
    "pretty:fix": "prettier --config ./.prettierrc.json --write \"**/*.{js,json}\"",
    "pretty:sol": "npx prettier --write --plugin=prettier-plugin-solidity contracts/**/*.sol",
    "coverage": "npx hardhat coverage",
    "size": "npx hardhat size-contracts",
    "test": "npx hardhat test",
    "claim-lowers": "node scripts/claim-lowers.js",
    "create-lowers": "node scripts/create-lowers.js",
    "get-lowers": "node scripts/get-lowers.js",
    "get-txids": "node scripts/get-txids.js",
    "regen-lowers": "node scripts/regenerate-lower-proofs.js",
    "verify-lowers": "node scripts/verify-used-lowers.js"
  }
}
